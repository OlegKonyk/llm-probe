# Production Environment Configuration
# Use this for AWS Lambda + Bedrock deployment

# =============================================================================
# API Key Authentication (Production)
# =============================================================================

# API key provider: "env" (single key) or "secrets-manager" (AWS)
# For production, use secrets-manager (multiple keys, automatic rotation)
API_KEY_PROVIDER=secrets-manager

# AWS Secrets Manager secret name containing API keys
# The secret should be JSON format: {"keys": [{"id": "...", "key": "..."}]}
API_KEYS_SECRET_NAME=prod/api-keys

# Cache TTL for API keys (in milliseconds, default: 300000 = 5 minutes)
# Higher values = fewer AWS API calls, but slower rotation detection
API_KEYS_CACHE_TTL_MS=300000

# =============================================================================
# LLM Provider Configuration (Production)
# =============================================================================

# Provider type: "ollama" (local) or "bedrock" (AWS)
# For production on AWS, use Bedrock (serverless, pay-per-use)
LLM_PROVIDER=bedrock

# =============================================================================
# AWS Bedrock Configuration
# =============================================================================

# AWS region where Bedrock is enabled
# Common regions: us-east-1, us-west-2, eu-west-1
AWS_REGION=us-east-1

# AWS credentials (required for Bedrock)
# Best Practice: Use IAM roles in Lambda instead of hardcoded credentials
# Only set these for testing; Lambda should use execution role
AWS_ACCESS_KEY_ID=your-access-key-here
AWS_SECRET_ACCESS_KEY=your-secret-key-here

# Bedrock model ID (default: Claude 3 Haiku)
# Recommended models:
# - anthropic.claude-3-haiku-20240307-v1:0 (fast, cost-effective)
# - anthropic.claude-3-sonnet-20240229-v1:0 (balanced)
# - anthropic.claude-3-opus-20240229-v1:0 (highest quality, expensive)
BEDROCK_MODEL=anthropic.claude-3-haiku-20240307-v1:0

# Generation timeout in milliseconds (default: 30000 = 30 seconds)
# Bedrock is typically faster than Ollama, but keep buffer for network latency
BEDROCK_TIMEOUT_MS=30000

# =============================================================================
# Server Configuration
# =============================================================================

# Server port (Lambda uses process.env.PORT or default 3000)
PORT=3000

# Node environment
NODE_ENV=production

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins (comma-separated for multiple origins)
# Production: Only allow your production frontend domain(s)
ALLOWED_ORIGINS=https://your-app.com,https://www.your-app.com

# =============================================================================
# Rate Limiting
# =============================================================================

# Time window for rate limiting (ms)
# Production: Stricter limits to prevent abuse
RATE_LIMIT_WINDOW_MS=900000

# Max requests per IP per window
# Production: Lower limit for better cost control
RATE_LIMIT_MAX_REQUESTS=50

# =============================================================================
# AWS Bedrock Model Access
# =============================================================================
# Before deploying, ensure you've enabled model access in AWS Console:
# 1. Navigate to: AWS Console → Bedrock → Model access
# 2. Enable access for: anthropic.claude-3-haiku-20240307-v1:0
# 3. Wait for "Access granted" status (usually < 1 minute)
#
# IAM Permissions Required:
# - bedrock:InvokeModel
# - bedrock:InvokeModelWithResponseStream (optional, for streaming)
#
# Example IAM Policy:
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Action": [
#         "bedrock:InvokeModel"
#       ],
#       "Resource": "arn:aws:bedrock:*::foundation-model/anthropic.claude-3-haiku-20240307-v1:0"
#     }
#   ]
# }

# =============================================================================
# AWS Secrets Manager Setup for API Keys
# =============================================================================
#
# 1. Create a new secret in AWS Secrets Manager:
#    - Type: "Other type of secret"
#    - Key/value pairs: Use JSON format below
#    - Secret name: prod/api-keys (or your custom name)
#
# 2. Secret JSON format:
# {
#   "keys": [
#     {
#       "id": "client-1",
#       "key": "sk_live_abc123...",
#       "description": "Production client 1"
#     },
#     {
#       "id": "client-2",
#       "key": "sk_live_xyz789...",
#       "description": "Production client 2"
#     }
#   ]
# }
#
# 3. Generate secure API keys:
#    openssl rand -hex 32
#
# 4. Add IAM permissions for Lambda execution role:
# {
#   "Version": "2012-10-17",
#   "Statement": [
#     {
#       "Effect": "Allow",
#       "Action": [
#         "secretsmanager:GetSecretValue"
#       ],
#       "Resource": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:prod/api-keys-*"
#     }
#   ]
# }
#
# 5. Rotate API keys:
#    - Update the secret in AWS Secrets Manager
#    - Cache TTL (5 min) ensures automatic pickup
#    - No code deployment required!
