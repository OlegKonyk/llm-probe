# Development Environment Configuration
# Copy this file to .env for local development

# =============================================================================
# API Key Authentication (Local Development)
# =============================================================================

# API key provider: "env" (single key) or "secrets-manager" (AWS)
# For local development, use env provider (simple, no AWS costs)
API_KEY_PROVIDER=env

# API key for local development
# Generate a secure random key: openssl rand -hex 32
# IMPORTANT: Keep this secret! Don't commit to git!
API_KEY=dev_sk_your_secret_api_key_here

# =============================================================================
# LLM Provider Configuration (Local Development)
# =============================================================================

# Provider type: "ollama" (local) or "bedrock" (AWS)
# For local development, use Ollama (free, fast, no AWS costs)
LLM_PROVIDER=ollama

# =============================================================================
# Ollama Configuration
# =============================================================================

# Ollama service URL (default: http://localhost:11434)
# Change this if running Ollama on a different host/port
OLLAMA_HOST=http://localhost:11434

# Ollama model to use (default: llama3.2:latest)
# Must be pulled first: ollama pull llama3.2:latest
OLLAMA_MODEL=llama3.2:latest

# Generation timeout in milliseconds (default: 30000 = 30 seconds)
OLLAMA_TIMEOUT_MS=30000

# =============================================================================
# Server Configuration
# =============================================================================

# Server port
PORT=3000

# Node environment
NODE_ENV=development

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed origins (comma-separated for multiple origins)
# Development: Allow localhost on multiple ports for frontend dev servers
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8080

# =============================================================================
# Rate Limiting
# =============================================================================

# Time window for rate limiting (ms)
RATE_LIMIT_WINDOW_MS=900000

# Max requests per IP per window
RATE_LIMIT_MAX_REQUESTS=100
